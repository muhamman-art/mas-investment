# MAS Investment Environment Variables
# Copy this file to .env and update values

# Django
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=mas_investment_db
DB_USER=mas_user
